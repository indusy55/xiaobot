root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
trim_trailing_whitespace = false

[*.{json,yml,yaml}]
indent_size = 2

[*.{html,css,scss,less}]
indent_size = 2

[*.{js,jsx,ts,tsx}]
indent_size = 2

[*.{vue,svelte,astro}]
indent_size = 2